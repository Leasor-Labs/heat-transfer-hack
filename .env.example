# Copy this file to .env and set values. Do not commit .env to version control.
# The server (npm run dev) loads .env from the project root automatically.
# Required for AWS SDK (Location, DynamoDB, etc.): set in .env or use AWS CLI / IAM role.

# -----------------------------------------------------------------------------
# AWS credentials (required for any AWS API calls from this app)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: AWS_SESSION_TOKEN=your-session-token

# -----------------------------------------------------------------------------
# AWS region (used by Location Service, DynamoDB, and map style)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# AWS Location Service – Place index (search & geocode)
# -----------------------------------------------------------------------------
# Name of your Amazon Location Service Place index resource (e.g. "MyPlaceIndex").
# If unset, place search and geocode are disabled; backup/fallback data may be used.
PLACE_INDEX_NAME=locationFinder

# -----------------------------------------------------------------------------
# AWS Location Service – Map tiles (optional)
# -----------------------------------------------------------------------------
# API key for Amazon Location Service map resource. If set, /api/map-style returns AWS map tiles.
# If unset, the app uses OpenStreetMap tiles.
# MAP_API_KEY=
# Map style name (e.g. Standard, Raster). Used only when MAP_API_KEY is set.
# MAP_STYLE=Standard

# -----------------------------------------------------------------------------
# DynamoDB tables (optional)
# -----------------------------------------------------------------------------
# Table names for heat sources and consumers. If unset, DynamoDB read/write is skipped.
# HEAT_SOURCES_TABLE=
# HEAT_CONSUMERS_TABLE=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=3000
